          },
          {
            "name": "Total de Beneficiários",
            "expression": "DISTINCTCOUNT( fato_bolsa_familia[NIS FAVORECIDO] )",
            "formatString": "0",
            "lineageTag": "2d7545b8-fac1-4906-97f7-9858af425eb8"
          },
          {
            "name": "Total de Municípios",
            "expression": "DISTINCTCOUNT( fato_bolsa_familia[CÓDIGO MUNICÍPIO SIAFI] )",
            "formatString": "0",
            "lineageTag": "2966d980-3849-4ddd-88c6-dbe562d16656"
          },
          {
            "name": "Ticket Médio",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "DIVIDE( [Total de Repasses], [Total de Beneficiários] )",
            "lineageTag": "82284e66-e01d-4794-acc7-ffa82b845e8c"
          }
