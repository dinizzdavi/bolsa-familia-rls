                "    #\"Tipo Alterado1\" = Table.TransformColumnTypes(#\"Tipo Alterado com Localidade\",{{\"MÊS COMPETÊNCIA\", type text}}),",
                "    #\"Personalização Adicionada\" = Table.AddColumn(#\"Tipo Alterado1\", \"Ano\", each Text.Start([#\"MÊS COMPETÊNCIA\"], 4)),",
                "    #\"Personalização Adicionada1\" = Table.AddColumn(#\"Personalização Adicionada\", \"Personalizar\", each Text.End([#\"MÊS COMPETÊNCIA\"], 2)),",
                "    #\"Colunas Renomeadas\" = Table.RenameColumns(#\"Personalização Adicionada1\",{{\"Personalizar\", \"Mês\"}})",
                "in",
