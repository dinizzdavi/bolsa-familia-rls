              "expression": [
                "let",
                "    Fonte = Csv.Document(File.Contents(\"C:\\Users\\davi.vdiniz\\Downloads\\amostra_bolsa.csv\"),[Delimiter=\",\", Columns=8, Encoding=65001, QuoteStyle=QuoteStyle.None]),",
