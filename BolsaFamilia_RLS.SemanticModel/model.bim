        "measures": [
          {
            "name": "Total de Repasses",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "SUM ( fato_bolsa_familia[VALOR PARCELA] )",
